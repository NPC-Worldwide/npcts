{
  "name": "npcts",
  "version": "0.1.24",
  "description": "NPC TypeScript SDK - A comprehensive UI component library for building AI-powered applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./ui": {
      "import": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./spatial": {
      "import": "./dist/ui/spatial/index.js",
      "types": "./dist/ui/spatial/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./server/spatial": {
      "import": "./dist/server/spatial/index.js",
      "types": "./dist/server/spatial/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "npc",
    "ai",
    "chat",
    "ui",
    "components",
    "react",
    "typescript",
    "spatial",
    "game-ui",
    "room-navigation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NPC-Worldwide/npcts"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc && node scripts/fix-esm-imports.mjs",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react-leaflet": "^4.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@codemirror/lang-javascript": "^6.2.1",
    "@codemirror/lang-python": "^6.1.3",
    "@uiw/react-codemirror": "^4.21.21",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chart.js": "^4.4.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "esbuild-wasm": "^0.24.2",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.294.0",
    "mammoth": "^1.11.0",
    "nunjucks": "^3.2.4",
    "react-chartjs-2": "^5.2.0",
    "react-force-graph-2d": "^1.25.4",
    "react-leaflet": "^5.0.0",
    "socket.io-client": "^4.7.0",
    "three": "^0.176.0",
    "three-stdlib": "^2.35.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.19.31",
    "@types/nunjucks": "^3.2.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.176.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  }
}
